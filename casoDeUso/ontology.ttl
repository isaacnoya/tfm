ogc:administrativeunit a owl:class ;
    rdfs:label "AU Unidades administrativas" ;
    rdfs:comment "Unidad de administración sobre la que un Estado miembro tiene y/o ejerce derechos jurisdiccionales para el gobierno local, regional y nacional." ;
    rdfs:subClassOf geo:Feature .

<http://www.ogc.org/agua:Zif_riesgo_pob_q500> a owl:class ;
    rdfs:label "NZ.Riesgo a la población Q500" ;
    rdfs:subClassOf geo:Feature .

ogc:lock a owl:class ;
    rdfs:label "HY-P Esclusa" ;
    rdfs:comment "Recinto con un par o una serie de puertas utilizado para hacer subir o bajar a los buques que pasan de un nivel de agua a otro." ;
    rdfs:subClassOf geo:Feature .

ogc:falls a owl:class ;
    rdfs:label "HY-P Cascada" ;
    rdfs:comment "Parte de un curso de agua que desciende verticalmente al caer desde una altura." ;
    rdfs:subClassOf geo:Feature ;
    owl:sameAs <http://geo.linkeddata.es/ontology/Cascada> .

ogc:wetland a owl:class ;
    rdfs:label "HY-P Humedal" ;
    rdfs:comment "Zona poco drenada o inundada periódicamente cuyo suelo se encuentra saturado de agua y admite vegetación." ;
    rdfs:subClassOf geo:Feature ;
    owl:sameAs <http://geo.linkeddata.es/ontology/Humedal> .

ogc:drainagebasin a owl:class ;
    rdfs:label "HY-P Cuenca de captación" ;
    rdfs:comment "Zona que tiene un desagüe común para su escorrentía." ;
    rdfs:subClassOf geo:Feature .

ogc:damorweir a owl:class ;
    rdfs:label "HY-P Presa o represa" ;
    rdfs:comment "Barrera permanente a través de un curso de agua, utilizada para almacenar agua o controlar su flujo." ;
    rdfs:subClassOf geo:Feature .

ogc:standingwater a owl:class ;
    rdfs:label "HY-P Aguas estancadas" ;
    rdfs:comment "Masa de agua que está rodeada por completo de tierra." ;
    rdfs:subClassOf geo:Feature ;
    owl:sameAs <http://geo.linkeddata.es/ontology/Surgencias> .

