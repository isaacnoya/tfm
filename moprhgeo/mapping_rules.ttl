@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix htv: <http://www.w3.org/2011/http#> .
@prefix ogc: <http://www.ogc.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rml: <http://w3id.org/rml/> .
@prefix void: <http://rdfs.org/ns/void#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ogc:railwaystationnodeTriplesMap2 a rml:TriplesMap ;
    rml:logicalSource ogc:LogicalSource_railwaystationnode ;
    rml:predicateObjectMap [ rml:object geo:FeatureCollection ;
            rml:predicate rdf:type ],
        [ rml:objectMap [ rml:parentTriplesMap ogc:railwaystationnodeTriplesMap ] ;
            rml:predicate geo:member ] ;
    rml:subjectMap [ rml:constant ogc:railwaystationnode_collection ] .

ogc:FuenteAPI_railwaystationnode htv:absoluteURI "https://api-features.idee.es//collections/railwaystationnode/items?f=json&limit=10000" .

ogc:railwaystationnodeTriplesMap a rml:TriplesMap ;
    rml:logicalSource ogc:LogicalSource_railwaystationnode ;
    rml:predicateObjectMap [ rml:object ogc:railwaystationnode ;
            rml:predicate rdf:type ],
        [ rml:objectMap [ void:filterx "geometry=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.geometry" ] ;
            rml:predicate ogc:geometry ],
        [ rml:objectMap [ void:filterx "nil_varios=@{1}" ;
                    rml:datatype xsd:boolean ;
                    rml:reference "properties.nil_varios" ] ;
            rml:predicate ogc:nil_varios ],
        [ rml:objectMap [ void:filterx "formofnode=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.formofnode" ] ;
            rml:predicate ogc:formofnode ],
        [ rml:objectMap [ void:filterx "nilreason_n_andenes=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.nilreason_n_andenes" ] ;
            rml:predicate ogc:nilreason_n_andenes ],
        [ rml:objectMap [ void:filterx "nil_nombre=@{1}" ;
                    rml:datatype xsd:boolean ;
                    rml:reference "properties.nil_nombre" ] ;
            rml:predicate ogc:nil_nombre ],
        [ rml:objectMap [ void:filterx "localid=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.localid" ] ;
            rml:predicate ogc:localid ],
        [ rml:objectMap [ void:filterx "fecha_alta=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.fecha_alta" ] ;
            rml:predicate ogc:fecha_alta ],
        [ rml:objectMap [ void:filterx "nombre=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.nombre" ] ;
            rml:predicate ogc:nombre ],
        [ rml:objectMap [ void:filterx "n_andenes=@{1}" ;
                    rml:datatype xsd:integer ;
                    rml:reference "properties.n_andenes" ] ;
            rml:predicate ogc:n_andenes ],
        [ rml:objectMap [ void:filterx "nil_n_andenes=@{1}" ;
                    rml:datatype xsd:boolean ;
                    rml:reference "properties.nil_n_andenes" ] ;
            rml:predicate ogc:nil_n_andenes ],
        [ rml:objectMap [ rml:datatype geo:geoJSONLiteral ;
                    rml:reference "geometry" ] ;
            rml:predicate geo:hasGeometry ],
        [ rml:objectMap [ void:filterx "nilreason_varios=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.nilreason_varios" ] ;
            rml:predicate ogc:nilreason_varios ],
        [ rml:objectMap [ rml:datatype xsd:string ;
                    rml:reference "geometry_name" ] ;
            rml:predicate ogc:geometryName ],
        [ rml:objectMap [ void:filterx "nilreason_nombre=@{1}" ;
                    rml:datatype xsd:string ;
                    rml:reference "properties.nilreason_nombre" ] ;
            rml:predicate ogc:nilreason_nombre ],
        [ rml:objectMap [ void:filterx "id_estfc=@{1}" ;
                    rml:datatype xsd:integer ;
                    rml:reference "properties.id_estfc" ] ;
            rml:predicate ogc:id_estfc ] ;
    rml:subjectMap [ rml:template "https://api-features.idee.es//railwaystationnode/items/{id}" ] .

ogc:LogicalSource_railwaystationnode a rml:logicalSource ;
    void:nextPage "$.links[?(@.rel==\"next\")].href" ;
    rml:iterator "$.features.*" ;
    rml:referenceFormulation rml:HTTPAPI ;
    rml:source ogc:FuenteAPI_railwaystationnode .

